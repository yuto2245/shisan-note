---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="ページが見つかりません" description="お探しのページは見つかりませんでした。">
	<section class="section">
		<div class="reading-container" style="text-align: center">
			<p class="eyebrow">404 Not found</p><h1 class="section-heading">ページが見つかりません</h1>
			<p class="section-intro" style="margin-inline: auto">URLが変更されたか、ページが削除された可能性があります。</p>
			<div class="hero-actions" style="justify-content: center"><a class="button" href="/">トップへ戻る</a><a class="button secondary" href="/articles/">記事を探す</a></div>
		</div>
	</section>
</BaseLayout>
