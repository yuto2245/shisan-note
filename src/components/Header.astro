---
import ThemeToggle from './ThemeToggle.astro';

const currentPath = Astro.url.pathname;
const links = [
	{ href: '/articles/', label: '記事一覧' },
	{ href: '/categories/', label: 'テーマ' },
	{ href: '/about/', label: 'このサイトについて' },
];
---

<header class="site-header">
	<div class="container header-inner">
		<a class="brand" href="/" aria-label="資産ノート トップページ">
			<span class="brand-mark" aria-hidden="true"><i></i><i></i><i></i></span>
			<span class="brand-copy"><strong>資産ノート</strong><small>SHISAN NOTE</small></span>
		</a>
		<nav class="desktop-nav" aria-label="メインナビゲーション">
			{links.map((link) => (
				<a href={link.href} aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}>{link.label}</a>
			))}
		</nav>
		<div class="header-actions">
			<ThemeToggle />
			<a class="header-cta" href="/articles/">読む <span aria-hidden="true">↗</span></a>
			<details class="mobile-nav">
				<summary aria-label="メニューを開く"><span aria-hidden="true">MENU</span></summary>
				<nav aria-label="モバイルナビゲーション">
					{links.map((link) => <a href={link.href}>{link.label}</a>)}
				</nav>
			</details>
		</div>
	</div>
</header>
