---
import type { Article } from '../lib/articles';
import { formatDate } from '../lib/articles';
import CategoryBadge from './CategoryBadge.astro';

interface Props { article: Article; featured?: boolean }
const { article, featured = false } = Astro.props;
---

<article class:list={['article-card', { featured }]}> 
	<a class="article-card-image" href={`/articles/${article.id}/`} tabindex="-1" aria-hidden="true">
		<img src={article.data.image} alt="" width="720" height="420" loading="lazy" />
	</a>
	<div class="article-card-body">
		<div class="article-meta">
			<CategoryBadge category={article.data.category} />
			<time datetime={article.data.publishedAt.toISOString()}>{formatDate(article.data.publishedAt)}</time>
		</div>
		<h3><a href={`/articles/${article.id}/`}>{article.data.title}</a></h3>
		<p>{article.data.description}</p>
		<a class="text-link" href={`/articles/${article.id}/`}>記事を読む <span aria-hidden="true">→</span></a>
	</div>
</article>
